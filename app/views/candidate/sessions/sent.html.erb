<% content_for :title, t('candidate.sessions.sent.title') %>

<div class="fr-grid-row full-height-grid">
  <div class="fr-col-12 fr-col-lg-7">
    <div class="fr-container--fluid">
      <div class="fr-mb-5w">
        <h1 class="fr-h1 fr-mb-1w"><%= t('candidate.sessions.sent.title') %></h1>
        <% if @reconnection_market_name %>
          <p class="fr-text--lg fr-mb-1w"><%= t('candidate.sessions.sent.message') %></p>
          <p class="fr-text--lg fr-mb-0">
            <%= t('candidate.sessions.sent.connection_market_intro') %>
            &ldquo;<strong><%= @reconnection_market_name %></strong>&rdquo;
          </p>
        <% else %>
          <p class="fr-text--lg fr-mb-0"><%= t('candidate.sessions.sent.message') %></p>
        <% end %>
      </div>

      <% if @magic_link_url %>
        <div class="fr-alert fr-alert--info fr-mb-3w">
          <p class="fr-alert__title"><%= Rails.env.capitalize %></p>
          <p>
            <%= link_to "Accéder directement (lien magique)", @magic_link_url, class: "fr-link" %>
          </p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="fr-col-12 fr-col-lg-1"></div>

  <div class="fr-col-12 fr-col-lg-4 fr-background-alt--blue-france">
    <div class="center-content">
      <%= image_tag 'form-logo.png', alt: t('candidate.shared.form_logo_alt') %>
    </div>
  </div>
</div>
