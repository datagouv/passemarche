<div class="fr-card fr-card--no-arrow fr-card--horizontal fr-mb-2w">
  <div class="fr-card__body">
    <div class="fr-card__content">
      <% if application.completed_at? %>
        <p class="fr-badge fr-badge--success fr-badge--sm fr-mb-2w">
          <%= t("candidate.dashboard.application.status.submitted").upcase %>
        </p>
      <% else %>
        <p class="fr-badge fr-badge--info fr-badge--sm fr-mb-2w">
          <%= t("candidate.dashboard.application.status.in_progress").upcase %>
        </p>
      <% end %>

      <h2 class="fr-h4 fr-mb-1w">
        <%= application.public_market.name %>
      </h2>

      <% if application.lots.any? %>
        <p class="fr-text--sm fr-mb-1w">
          <%= t("candidate.dashboard.application.lots_count", count: application.lots.size) %>
        </p>
      <% end %>

      <p class="fr-text--sm fr-text--mention-grey fr-mb-0">
        <span class="fr-icon-building-line fr-icon--sm" aria-hidden="true"></span>
        <%= application.public_market.buyer_name.presence || application.public_market.siret %>

        <% if application.completed_at? %>
          &nbsp;
          <span class="fr-icon-calendar-line fr-icon--sm" aria-hidden="true"></span>
          <%= t("candidate.dashboard.application.submitted_on",
                date: l(application.completed_at.to_date, format: '%-d %B %Y')) %>
        <% else %>
          &nbsp;
          <span class="fr-icon-edit-line fr-icon--sm" aria-hidden="true"></span>
          <%= t("candidate.dashboard.application.modified_on",
                date: l(application.updated_at.to_date, format: '%-d %B %Y')) %>
        <% end %>
      </p>
    </div>

    <div class="fr-card__footer">
      <ul class="fr-btns-group fr-btns-group--sm fr-btns-group--inline fr-btns-group--right">
        <% if application.completed_at? %>
          <li>
            <button class="fr-btn fr-btn--sm fr-btn--secondary" disabled aria-disabled="true">
              <%= t("candidate.dashboard.actions.view") %>
            </button>
          </li>
        <% else %>
          <li>
            <button class="fr-btn fr-btn--sm fr-btn--secondary fr-btn--tertiary fr-btn--icon-left"
                    data-fr-opened="false"
                    aria-controls="deletion-modal-<%= application.identifier %>">
              <span class="fr-icon-delete-bin-line fr-icon--sm" aria-hidden="true"></span>
              <%= t("candidate.dashboard.actions.delete") %>
            </button>
          </li>
          <li>
            <%= link_to company_identification_candidate_market_application_path(application.identifier),
                  class: "fr-btn fr-btn--sm fr-btn--icon-left" do %>
              <span class="fr-icon-edit-line fr-icon--sm" aria-hidden="true"></span>
              <%= t("candidate.dashboard.actions.edit") %>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<%= render "delete_modal", application: application unless application.completed_at? %>
