<dialog aria-labelledby="deletion-modal-title-<%= application.identifier %>"
        id="deletion-modal-<%= application.identifier %>"
        class="fr-modal"
        role="dialog">
  <div class="fr-container fr-container--fluid fr-container-md">
    <div class="fr-grid-row fr-grid-row--center">
      <div class="fr-col-12 fr-col-md-8 fr-col-lg-6">
        <div class="fr-modal__body">
          <div class="fr-modal__header">
            <button class="fr-btn--close fr-btn"
                    title="<%= t("candidate.dashboard.application.delete_modal.close") %>"
                    aria-controls="deletion-modal-<%= application.identifier %>">
              <%= t("candidate.dashboard.application.delete_modal.close") %>
            </button>
          </div>
          <div class="fr-modal__content">
            <h1 id="deletion-modal-title-<%= application.identifier %>"
                class="fr-modal__title">
              <span class="fr-icon-delete-bin-line fr-icon--lg" aria-hidden="true"></span>
              <%= t("candidate.dashboard.application.delete_modal.title") %>
            </h1>
            <p><%= t("candidate.dashboard.application.delete_modal.body") %></p>
          </div>
          <div class="fr-modal__footer">
            <ul class="fr-btns-group fr-btns-group--right fr-btns-group--inline fr-btns-group--icon-left fr-btns-group--reverse">
              <li>
                <%= button_to t("candidate.dashboard.application.delete_modal.confirm"),
                              candidate_market_application_path(application.identifier),
                              method: :delete,
                              class: "fr-btn" %>
              </li>
              <li>
                <button class="fr-btn fr-btn--secondary"
                        aria-controls="deletion-modal-<%= application.identifier %>">
                  <%= t("candidate.dashboard.application.delete_modal.cancel") %>
                </button>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</dialog>
