<fieldset class="fr-fieldset fr-mb-3w">
  <legend class="fr-fieldset__legend fr-h4">
    <%= t('admin.socle_de_base.form.market_types.title') %>
  </legend>

  <p class="fr-hint-text fr-mb-2w"><%= t('admin.socle_de_base.form.market_types.hint') %></p>

  <% @market_types.each do |market_type| %>
    <div class="fr-fieldset__element">
      <div class="fr-checkbox-group">
        <%= form.check_box :market_type_ids,
              { multiple: true, class: "fr-checkbox", id: "market_type_#{market_type.id}" },
              market_type.id, nil %>
        <%= form.label "market_type_ids_#{market_type.id}",
              t("market_types.#{market_type.code}", default: market_type.code.humanize),
              class: "fr-label",
              for: "market_type_#{market_type.id}" %>
      </div>
    </div>
  <% end %>
</fieldset>
