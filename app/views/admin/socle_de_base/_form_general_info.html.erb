<fieldset class="fr-fieldset fr-mb-3w">
  <legend class="fr-fieldset__legend fr-h4"><%= t('admin.socle_de_base.form.general_info.title') %></legend>

  <div class="fr-fieldset__element">
    <div class="fr-select-group">
      <%= form.label :input_type, t('admin.socle_de_base.form.general_info.input_type'), class: "fr-label" do %>
        <%= t('admin.socle_de_base.form.general_info.input_type') %>
        <span class="fr-hint-text"><%= t('admin.socle_de_base.form.general_info.input_type_hint') %></span>
      <% end %>
      <%= form.select :input_type,
            options_for_select(@input_types.map { |t| [t.humanize, t] }),
            { prompt: t('admin.socle_de_base.form.general_info.input_type_prompt') },
            class: "fr-select" %>
    </div>
  </div>

  <div class="fr-fieldset__element">
    <div class="fr-checkbox-group">
      <%= form.check_box :mandatory, class: "fr-checkbox" %>
      <%= form.label :mandatory, class: "fr-label" do %>
        <%= t('admin.socle_de_base.form.general_info.mandatory') %>
        <span class="fr-hint-text"><%= t('admin.socle_de_base.form.general_info.mandatory_hint') %></span>
      <% end %>
    </div>
  </div>
</fieldset>
