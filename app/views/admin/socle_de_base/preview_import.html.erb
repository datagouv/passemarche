<%= content_for :page_title, t('admin.socle_de_base.import_preview.title') %>

<div class="fr-container fr-my-4w">
  <%= render 'admin/shared/navigation' %>

  <h1 class="fr-h2 fr-mt-4w"><%= t('admin.socle_de_base.import_preview.title') %></h1>

  <div class="fr-alert fr-alert--info fr-mb-3w">
    <p>
      <%= t('admin.socle_de_base.import_preview.summary',
            creates: @statistics[:created],
            updates: @statistics[:updated],
            deletes: @statistics[:soft_deleted]) %>
    </p>
  </div>

  <% if @changes[:creates].any? %>
    <div class="fr-mb-3w">
      <h2 class="fr-h5 fr-mb-2w">
        <span class="fr-icon-add-circle-line fr-mr-1w" aria-hidden="true"></span>
        <%= t('admin.socle_de_base.import_preview.creates_title', count: @changes[:creates].size) %>
      </h2>
      <div class="fr-grid-row fr-grid-row--gutters">
        <% @changes[:creates].each do |entry| %>
          <div class="fr-col-12 fr-col-md-6 fr-col-lg-4">
            <div class="fr-card fr-card--sm fr-card--grey">
              <div class="fr-card__body">
                <div class="fr-card__content">
                  <p class="fr-badge fr-badge--sm fr-badge--success fr-mb-1w">Création</p>
                  <p class="fr-text--bold fr-mb-0"><code class="fr-text--xs"><%= entry[:key] %></code></p>
                  <p class="fr-text--sm fr-mb-0"><%= entry[:buyer_name] %></p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <% if @changes[:updates].any? %>
    <div class="fr-mb-3w">
      <h2 class="fr-h5 fr-mb-2w">
        <span class="fr-icon-edit-line fr-mr-1w" aria-hidden="true"></span>
        <%= t('admin.socle_de_base.import_preview.updates_title', count: @changes[:updates].size) %>
      </h2>
      <% @changes[:updates].each do |entry| %>
        <div class="fr-card fr-card--sm fr-card--grey fr-mb-2w">
          <div class="fr-card__body">
            <div class="fr-card__content">
              <div class="fr-grid-row fr-grid-row--middle fr-mb-1w">
                <div class="fr-col">
                  <p class="fr-text--bold fr-mb-0"><code class="fr-text--xs"><%= entry[:key] %></code></p>
                  <p class="fr-text--sm fr-mb-0"><%= entry[:buyer_name] %></p>
                </div>
                <div class="fr-col-auto">
                  <p class="fr-badge fr-badge--sm fr-badge--info">Modification</p>
                </div>
              </div>
              <% entry[:diff].each do |field, values| %>
                <div class="fr-text--xs fr-mb-1v" style="padding-left: 0.5rem; border-left: 2px solid var(--border-action-high-blue-france)">
                  <strong><%= field %></strong> :
                  <del style="opacity: 0.6"><%= values[:from] %></del>
                  &rarr;
                  <ins style="text-decoration: none; font-weight: bold"><%= values[:to] %></ins>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <% if @changes[:deletes].any? %>
    <div class="fr-mb-3w">
      <h2 class="fr-h5 fr-mb-2w">
        <span class="fr-icon-delete-line fr-mr-1w" aria-hidden="true"></span>
        <%= t('admin.socle_de_base.import_preview.deletes_title', count: @changes[:deletes].size) %>
      </h2>
      <div class="fr-grid-row fr-grid-row--gutters">
        <% @changes[:deletes].each do |entry| %>
          <div class="fr-col-12 fr-col-md-6 fr-col-lg-4">
            <div class="fr-card fr-card--sm fr-card--grey">
              <div class="fr-card__body">
                <div class="fr-card__content">
                  <p class="fr-badge fr-badge--sm fr-badge--error fr-mb-1w">Archivage</p>
                  <p class="fr-text--bold fr-mb-0"><code class="fr-text--xs"><%= entry[:key] %></code></p>
                  <p class="fr-text--sm fr-mb-0"><%= entry[:buyer_name] %></p>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <div class="fr-btns-group fr-btns-group--inline fr-mt-4w">
    <%= form_with url: import_admin_socle_de_base_index_path, method: :post, data: { turbo: false } do |f| %>
      <%= f.hidden_field :import_token, value: @import_token %>
      <%= f.submit t('admin.socle_de_base.import_preview.confirm'), class: 'fr-btn' %>
    <% end %>
    <%= link_to t('admin.socle_de_base.import_preview.cancel'), admin_socle_de_base_index_path, class: 'fr-btn fr-btn--secondary' %>
  </div>
</div>
