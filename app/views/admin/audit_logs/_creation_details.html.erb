<div class="fr-grid-row fr-grid-row--gutters">
  <% buyer_changes = changes.select { |k, _| k.start_with?('buyer_') } %>
  <% candidate_changes = changes.select { |k, _| k.start_with?('candidate_') } %>
  <% other_changes = changes.reject { |k, _| k.start_with?('buyer_') || k.start_with?('candidate_') || %w[updated_at created_at id].include?(k) } %>

  <% if buyer_changes.any? %>
    <div class="fr-col-12 fr-col-md-6">
      <h3 class="fr-h5"><%= t('admin.audit_logs.show.buyer_content') %></h3>
      <div class="fr-table fr-table--bordered">
        <table>
          <thead>
            <tr>
              <th><%= t('admin.audit_logs.show.field') %></th>
              <th><%= t('admin.audit_logs.show.value') %></th>
            </tr>
          </thead>
          <tbody>
            <% buyer_changes.each do |attr_name, (_, value)| %>
              <tr>
                <td class="fr-text--bold"><%= human_attribute_label(attr_name) %></td>
                <td><%= format_change_value(value) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if candidate_changes.any? %>
    <div class="fr-col-12 fr-col-md-6">
      <h3 class="fr-h5"><%= t('admin.audit_logs.show.candidate_content') %></h3>
      <div class="fr-table fr-table--bordered">
        <table>
          <thead>
            <tr>
              <th><%= t('admin.audit_logs.show.field') %></th>
              <th><%= t('admin.audit_logs.show.value') %></th>
            </tr>
          </thead>
          <tbody>
            <% candidate_changes.each do |attr_name, (_, value)| %>
              <tr>
                <td class="fr-text--bold"><%= human_attribute_label(attr_name) %></td>
                <td><%= format_change_value(value) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <% if other_changes.any? %>
    <div class="fr-col-12">
      <div class="fr-table fr-table--bordered">
        <table>
          <thead>
            <tr>
              <th><%= t('admin.audit_logs.show.field') %></th>
              <th><%= t('admin.audit_logs.show.value') %></th>
            </tr>
          </thead>
          <tbody>
            <% other_changes.each do |attr_name, (_, value)| %>
              <tr>
                <td class="fr-text--bold"><%= human_attribute_label(attr_name) %></td>
                <td><%= format_change_value(value) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>
</div>
